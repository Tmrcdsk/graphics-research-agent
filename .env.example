# DeepSeek
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Runtime
APP_ENV=development
DATABASE_URL=sqlite:///./data/agent.sqlite3
DRY_RUN=true
TIMEZONE=Asia/Tokyo
LOG_LEVEL=INFO
# Optional Docker build override for networks that cannot pull from Docker Hub.
PYTHON_IMAGE=python:3.11-slim

# Pipeline
ENABLED_SOURCES=arxiv,unreal,nvidia
ARXIV_CATEGORIES=cs.GR,cs.CV,cs.LG
MAX_ARXIV_RESULTS=80
MAX_FEED_RESULTS=20
UNREAL_FEED_URL=https://www.unrealengine.com/rss
NVIDIA_FEED_URL=https://developer.nvidia.com/blog/feed/
MAX_PUSH_MUST_READ=3
MAX_PUSH_READ_LATER=5
RULE_FILTER_THRESHOLD=5

# Scheduler
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
